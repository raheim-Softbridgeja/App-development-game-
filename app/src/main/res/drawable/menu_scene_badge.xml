<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="112dp"
        android:height="112dp"
        android:gravity="center">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:endColor="#FFF28A5B"
                android:startColor="#FFF7D36A" />
        </shape>
    </item>

    <item
        android:width="76dp"
        android:height="76dp"
        android:gravity="top|center_horizontal"
        android:top="10dp">
        <shape android:shape="oval">
            <solid android:color="#26FFFFFF" />
        </shape>
    </item>

    <item
        android:width="82dp"
        android:height="18dp"
        android:gravity="bottom|center_horizontal"
        android:bottom="24dp">
        <shape>
            <corners android:radius="12dp" />
            <solid android:color="#FF3BB6C6" />
        </shape>
    </item>

    <item
        android:width="54dp"
        android:height="20dp"
        android:gravity="bottom|center_horizontal"
        android:bottom="32dp">
        <shape android:shape="oval">
            <solid android:color="#FF7D5A3A" />
        </shape>
    </item>

    <item
        android:width="8dp"
        android:height="42dp"
        android:gravity="bottom|center_horizontal"
        android:bottom="36dp"
        android:left="-20dp">
        <shape>
            <corners android:radius="4dp" />
            <solid android:color="#FF6A4629" />
        </shape>
    </item>

    <item
        android:width="30dp"
        android:height="12dp"
        android:gravity="bottom|center_horizontal"
        android:bottom="68dp"
        android:left="-10dp">
        <shape android:shape="oval">
            <solid android:color="#FF2A9D8F" />
        </shape>
    </item>

    <item
        android:width="34dp"
        android:height="12dp"
        android:gravity="bottom|center_horizontal"
        android:bottom="58dp"
        android:left="14dp">
        <shape android:shape="oval">
            <solid android:color="#FF56C271" />
        </shape>
    </item>
</layer-list>
